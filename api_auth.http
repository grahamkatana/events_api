@baseUrl = http://localhost:3000

### Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "you@example.com",
  "password": "supersecret123"
}

### Login (this response gets captured as "login" below)
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "you@example.com",
  "password": "supersecret123"
}

### Try creating an event WITHOUT a token (should be 401)
POST {{baseUrl}}/events
Content-Type: application/json

{
  "name": "Should Fail"
}

### Create an event WITH the token from login above (should succeed)
POST {{baseUrl}}/events
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "name": "Protected Event"
}
